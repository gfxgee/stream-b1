# AI provider switch: "gemini" (default) or "openai"
AI_PROVIDER=gemini

# Google Gemini (server-side only — never expose to the browser)
GEMINI_API_KEY=
# Optional model override (default: gemini-2.5-flash)
GEMINI_MODEL=

# OpenAI (used when AI_PROVIDER=openai)
OPENAI_API_KEY=
# Optional model override (default: gpt-4o-mini)
OPENAI_MODEL=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Google PageSpeed Insights (optional — used by the Audit pipeline).
# Works without a key at low volume, but a free key raises the rate limit.
# Get one at https://developers.google.com/speed/docs/insights/v5/get-started
PAGESPEED_API_KEY=
